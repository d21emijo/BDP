    "\n",
    "    wrong_pairs = [(t, pred) for t, pred in zip(y_true, y_pred) if t != pred]\n",
    "    counts = Counter(wrong_pairs).most_common(top_n)\n",
    "\n",
    "    \n",
    "    for (true_idx, pred_idx), count in counts:\n",
