    "def make_callbacks(corruption_name, p):\n",
    "    run_name = f\"{corruption_name}_p{int(p*100)}_{datetime.now().strftime('%Y%m%d-%H%M%S')}\"\n",
    "    log_dir = os.path.join(\"logs\", run_name)\n",
    "\n",
    "    tb = tf.keras.callbacks.TensorBoard(\n",
    "        log_dir=log_dir,\n",
    "        histogram_freq=0,\n",
    "        write_graph=True,\n",
    "        update_freq=\"batch\",\n",
    "        profile_batch=0\n",
    "    )\n",
    "\n",
    "    return [tb], log_dir"
   ]
  },
  {
